%% DECP Platform - CI/CD Pipeline Diagram
%% Shows GitHub Actions workflow with build, test, deploy stages

flowchart TB
    subgraph DevTeam["👨‍💻 Development Team"]
        Developer["Developer"]
        CodeReview["Code Reviewer"]
    end

    subgraph VersionControl["📁 Version Control"]
        GitHub["GitHub Repository<br/>decp-platform"]
        
        subgraph Branches["Branch Strategy"]
            Main["main<br/>(Production)"]
            Develop["develop<br/>(Integration)"]
            Feature["feature/*<br/>(Feature Development)"]
            Hotfix["hotfix/*<br/>(Emergency Fixes)"]
            Release["release/*<br/>(Release Prep)"]
        end
    end

    subgraph CIPipeline["🔄 CI Pipeline - GitHub Actions"]
        subgraph Trigger["Trigger"]
            PushEvent["Push Event"]
            PREvent["Pull Request Event"]
            ManualTrigger["Manual Trigger"]
        end

        subgraph BuildStage["📦 Build Stage"]
            Checkout["Checkout Code"]
            SetupNode["Setup Node.js<br/>Setup Python"]
            InstallDeps["Install Dependencies<br/>npm ci / pip install"]
            Lint["Linting<br/>ESLint / Prettier / Black"]
            TypeCheck["Type Check<br/>TypeScript / MyPy"]
        end

        subgraph TestStage["🧪 Test Stage"]
            UnitTests["Unit Tests<br/>Jest / Pytest"]
            IntegrationTests["Integration Tests<br/>Supertest / TestContainers"]
            CodeCoverage["Code Coverage<br/>Codecov / SonarQube"]
            SecurityScan["Security Scan<br/>Snyk / npm audit"]
        end

        subgraph ArtifactStage["📤 Artifact Stage"]
            BuildApp["Build Application<br/>npm run build"]
            BuildDocker["Build Docker Images<br/>Dockerfile.multi"]
            ScanImages["Scan Images<br/>Trivy / Clair"]
            PushRegistry["Push to Registry<br/>AWS ECR / Docker Hub"]
        end
    end

    subgraph CDPipeline["🚀 CD Pipeline - GitHub Actions"]
        subgraph DevDeploy["Development Deployment"]
            DeployDevK8s["Deploy to Dev K8s<br/>kubectl apply"]
            SmokeTestDev["Smoke Tests<br/>Health Checks"]
        end

        subgraph StagingDeploy["Staging Deployment"]
            DeployStagingK8s["Deploy to Staging K8s"]
            IntegrationTestStaging["Integration Tests"]
            E2ETests["E2E Tests<br/>Cypress / Playwright"]
            PerformanceTests["Performance Tests<br/>k6 / Artillery"]
        end

        subgraph ProductionDeploy["🎉 Production Deployment"]
            ApprovalGate["Manual Approval<br/>Required"]
            
            subgraph BlueGreen["Blue-Green Deployment"]
                DeployBlue["Deploy to Green<br/>(Inactive)"]
                HealthCheck["Health Checks"]
                SwitchTraffic["Switch Traffic<br/>to Green"]
                Monitor["Monitor Metrics"]
                Rollback["Auto Rollback<br/>if errors"]
            end
            
            TagRelease["Tag Release<br/>v1.x.x"]
            GenerateChangelog["Generate Changelog"]
        end
    end

    subgraph Environments["🌍 Deployment Environments"]
        subgraph DevEnv["Development"]
            DevK8s["Kubernetes Cluster<br/>Dev Namespace"]
            DevDB["Dev Database<br/>Single Instance"]
        end

        subgraph StagingEnv["Staging"]
            StagingK8s["Kubernetes Cluster<br/>Staging Namespace"]
            StagingDB["Staging Database<br/>Multi-AZ"]
        end

        subgraph ProdEnv["Production"]
            ProdK8s["Kubernetes Cluster<br/>Production"]
            ProdDB["Production Database<br/>Multi-AZ + Read Replicas"]
            CDN["CDN<br/>CloudFront"]
        end
    end

    subgraph Observability["📊 Observability"]
        Monitoring["Monitoring<br/>Prometheus / Grafana"]
        Logging["Logging<br/>ELK Stack / CloudWatch"]
        Alerting["Alerting<br/>PagerDuty / Slack"]
    end

    %% Developer Workflow
    Developer -->|"1. Push code"| Feature
    Feature -->|"2. Create PR"| Develop
    CodeReview -->|"3. Review & Approve"| Feature
    Develop -->|"4. Merge to develop"| PushEvent
    Develop -->|"5. Release branch"| Release
    Release -->|"6. Merge to main"| Main
    Hotfix -->|"Emergency fix"| Main
    Main -->|"Triggers"| PushEvent

    %% CI Pipeline Flow
    PushEvent --> Checkout
    PREvent --> Checkout
    ManualTrigger --> Checkout
    
    Checkout --> SetupNode
    SetupNode --> InstallDeps
    InstallDeps --> Lint
    Lint --> TypeCheck
    TypeCheck --> UnitTests
    UnitTests --> IntegrationTests
    IntegrationTests --> CodeCoverage
    CodeCoverage --> SecurityScan
    SecurityScan --> BuildApp
    BuildApp --> BuildDocker
    BuildDocker --> ScanImages
    ScanImages --> PushRegistry

    %% CD Pipeline Flow - Dev
    PushRegistry -->|"develop branch"| DeployDevK8s
    DeployDevK8s --> DevK8s
    DevK8s --> SmokeTestDev
    SmokeTestDev -->|"Pass"| DevDB

    %% CD Pipeline Flow - Staging
    SmokeTestDev -->|"Manual trigger"| DeployStagingK8s
    DeployStagingK8s --> StagingK8s
    StagingK8s --> IntegrationTestStaging
    IntegrationTestStaging --> E2ETests
    E2ETests --> PerformanceTests
    PerformanceTests -->|"Pass"| StagingDB

    %% CD Pipeline Flow - Production
    PerformanceTests -->|"release branch"| ApprovalGate
    ApprovalGate --> DeployBlue
    DeployBlue --> ProdK8s
    ProdK8s --> HealthCheck
    HealthCheck --> SwitchTraffic
    SwitchTraffic --> Monitor
    Monitor -->|"Success"| TagRelease
    Monitor -->|"Failure"| Rollback
    TagRelease --> GenerateChangelog
    SwitchTraffic --> CDN
    ProdK8s --> ProdDB

    %% Observability
    DevK8s -.->|"Metrics/Logs"| Monitoring
    StagingK8s -.->|"Metrics/Logs"| Monitoring
    ProdK8s -.->|"Metrics/Logs"| Monitoring
    Monitoring -.->|"Alerts"| Alerting
    Logging -.->|"Aggregates"| Monitoring

    %% Styling
    classDef team fill:#08427b,stroke:#052e56,color:#fff,stroke-width:2px
    classDef git fill:#6cc644,stroke:#4a8f32,color:#fff,stroke-width:2px
    classDef ci fill:#2088ff,stroke:#0066cc,color:#fff,stroke-width:2px
    classDef cd fill:#ff6b6b,stroke:#cc5555,color:#fff,stroke-width:2px
    classDef env fill:#ffd93d,stroke:#ccae31,color:#000,stroke-width:2px
    classDef prod fill:#ff6b6b,stroke:#cc5555,color:#fff,stroke-width:3px
    classDef obs fill:#9b59b6,stroke:#7d3c98,color:#fff,stroke-width:2px
    classDef stage fill:#f5f5f5,stroke:#9e9e9e,stroke-width:2px

    class Developer,CodeReview team
    class GitHub,Branches,Main,Develop,Feature,Hotfix,Release git
    class CIPipeline,Trigger,BuildStage,TestStage,ArtifactStage,Checkout,SetupNode,InstallDeps,Lint,TypeCheck,UnitTests,IntegrationTests,CodeCoverage,SecurityScan,BuildApp,BuildDocker,ScanImages,PushRegistry ci
    class CDPipeline,DevDeploy,StagingDeploy,ProductionDeploy,ApprovalGate,BlueGreen,DeployBlue,HealthCheck,SwitchTraffic,Monitor,Rollback,TagRelease,GenerateChangelog cd
    class Environments,DevEnv,StagingEnv,DevK8s,DevDB,StagingK8s,StagingDB env
    class ProdEnv,ProdK8s,ProdDB,CDN prod
    class Observability,Monitoring,Logging,Alerting obs

    %% Title
    Title["🚀 DECP Platform - CI/CD Pipeline Diagram"]
    style Title fill:#2088ff,stroke:#0066cc,color:#fff,stroke-width:3px
