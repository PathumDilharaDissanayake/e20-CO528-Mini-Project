NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=your-super-secret-jwt-key
JWT_REFRESH_SECRET=your-super-secret-refresh-key

# Service URLs
AUTH_SERVICE_URL=http://auth-service:3001
USER_SERVICE_URL=http://user-service:3002
FEED_SERVICE_URL=http://feed-service:3003
JOBS_SERVICE_URL=http://jobs-service:3004
EVENTS_SERVICE_URL=http://events-service:3005
RESEARCH_SERVICE_URL=http://research-service:3006
MESSAGING_SERVICE_URL=http://messaging-service:3007
NOTIFICATION_SERVICE_URL=http://notification-service:3008
ANALYTICS_SERVICE_URL=http://analytics-service:3009

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
